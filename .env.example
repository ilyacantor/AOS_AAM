# Salesforce OAuth Connector - Environment Configuration

# REQUIRED: Salesforce OAuth Callback URL
# This is the URL Salesforce will redirect to after user authorization
# Format: https://<your-replit-url>/oauth/callback/salesforce
# 
# HOW TO GET THIS:
# 1. After starting your Replit, copy the public URL (e.g., https://yourproject.username.repl.co)
# 2. Append /oauth/callback/salesforce to it
# 3. Set this value and ALSO configure it in your Salesforce Connected App
SALESFORCE_CALLBACK_URL=https://your-replit-url.repl.co/oauth/callback/salesforce

# Optional: If not set, will try to auto-detect from REPL_SLUG
# REPL_SLUG=your-project-name
