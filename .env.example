# =============================================================================
# AOS-AAM Environment Variables
# Copy to .env and fill in values. All secrets should be set via Render dashboard.
# =============================================================================

# --- Database ---
AAM_DATABASE_URL=aam.db

# --- Logging ---
AAM_LOG_LEVEL=INFO

# --- AOD Integration ---
AAM_AOD_PAYLOAD_FILE=aod_last_payload.json

# --- Drift Detection Thresholds ---
AAM_DRIFT_LATENCY_THRESHOLD_MS=1000
AAM_DRIFT_CONSUMER_LAG_THRESHOLD=10000
AAM_DRIFT_CONNECTION_TIMEOUT_S=30

# --- Runner Configuration ---
AAM_RUNNER_JOB_TIMEOUT_S=300

# --- DCL Integration ---
# Base URL for DCL service (AAM derives ingest/export endpoints from this)
DCL_URL=

# Base URL for AAM self-referencing (Runner → DCL ingest)
AAM_BASE_URL=

# API key for AAM → DCL communication
AAM_DCL_API_KEY=

# --- Farm Integration ---
# Farm manifest intake endpoint for dispatching extraction jobs
FARM_INTAKE_URL=

# --- Supabase (Optional - for production persistence) ---
SUPABASE_URL=
SUPABASE_DB_PASSWORD=
